{
  "Interface": {
    "prefix": "interface",
    "body": [
      "interface ${1:Name} {",
      "\tdef ${2:method}(${3:params}) -> ${4:ReturnType};",
      "}"
    ],
    "description": "Interface declaration"
  },
  "Abstract Class": {
    "prefix": "abstract class",
    "body": [
      "abstract class ${1:Name} {",
      "\tabstract def ${2:method}() -> ${3:ReturnType};",
      "\t",
      "\tdef ${4:concrete_method}() -> None {",
      "\t\t${5:pass};",
      "\t}",
      "}"
    ],
    "description": "Abstract class with abstract and concrete methods"
  },
  "Final Class": {
    "prefix": "final class",
    "body": [
      "final class ${1:Name} {",
      "\tdef __init__(self${2:, params}) -> None {",
      "\t\t${3:pass};",
      "\t}",
      "}"
    ],
    "description": "Final class that cannot be inherited"
  },
  "Static Method": {
    "prefix": "static def",
    "body": [
      "static def ${1:method_name}(${2:params}) -> ${3:ReturnType} {",
      "\t${4:pass};",
      "}"
    ],
    "description": "Static method declaration"
  },
  "Extends Class": {
    "prefix": "class extends",
    "body": [
      "class ${1:Child} extends ${2:Parent} {",
      "\tdef __init__(self${3:, params}) -> None {",
      "\t\tsuper().__init__(${4:parent_params});",
      "\t\t${5:pass};",
      "\t}",
      "}"
    ],
    "description": "Class with inheritance"
  },
  "Implements Interface": {
    "prefix": "class implements",
    "body": [
      "class ${1:Name} implements ${2:Interface} {",
      "\tdef ${3:interface_method}(${4:params}) -> ${5:ReturnType} {",
      "\t\t${6:pass};",
      "\t}",
      "}"
    ],
    "description": "Class implementing an interface"
  },
  "Enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:FIRST},",
      "\t${3:SECOND}",
      "}"
    ],
    "description": "Enum declaration"
  },
  "Data Class": {
    "prefix": "data class",
    "body": [
      "data class ${1:Name}(${2:field}: ${3:Type});"
    ],
    "description": "Data class declaration"
  },
  "Switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:value}) {",
      "\tcase ${2:pattern}: {",
      "\t\t${3:pass};",
      "\t}",
      "\tdefault: {",
      "\t\t${4:pass};",
      "\t}",
      "}"
    ],
    "description": "Switch statement with cases and a default"
  },
  "Runtime Annotation": {
    "prefix": "@",
    "body": [
      "@${1:decorator}"
    ],
    "description": "Runtime annotation (emitted as a Python decorator)"
  },
  "Compile-time Annotation": {
    "prefix": "@!",
    "body": [
      "@!${1:annotation}"
    ],
    "description": "Compile-time annotation (processed by the compiler, then stripped)"
  },
  "Print On Call": {
    "prefix": "@!print_on_call",
    "body": [
      "@!print_on_call(time_format=\"${1:%H:%M:%S}\")"
    ],
    "description": "Inject a timestamped log line when the function is called"
  }
}